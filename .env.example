# Copy this file to `.env` in the project root and adjust. Restart services after changes.
#
# Used by:
# - Next.js (NEXT_PUBLIC_*)
# - docker-compose `api` + `frontend` services (env_file: .env) — same file supplies ZOOM_*, DB_*, JWT_*, etc.
#
# Production: keep this file next to `docker-compose.deploy.yml` on the server (e.g. ~/kiplombe-hmis/.env).
# If your secrets live elsewhere, either symlink that path to `.env` here, add a second path under `env_file:`
# in docker-compose.deploy.yml, or set API_ENV_FILE=/full/path/.env for the Node API (see api/config/load-env.js).
# API_ENV_FILE=
#
# Browser must call the Node API directly when Next runs on a different port (e.g. 3004 vs API 3003).
# If unset, requests go to the same host as the page (often wrong in local dev).
NEXT_PUBLIC_API_URL=http://localhost:3003

# Optional: public URL of this Next app (QR codes, absolute links)
# NEXT_PUBLIC_BASE_URL=http://localhost:3004

# --- Zoom Meeting SDK (embedded video in HMIS) — read by Node API only, not exposed to the browser ---
# From Zoom Marketplace → your Meeting SDK app → App Credentials (Client ID / Client Secret).
# Same as ZOOM_MEETING_SDK_KEY / ZOOM_MEETING_SDK_SECRET if you prefer those names.
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=

# Running API without Docker: copy these lines into `api/.env` if you use dotenv there, or export in shell.
