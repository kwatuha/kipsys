# Copy to `.env.local` in the project root (Next.js). Restart `next dev` after changes.
#
# When the UI runs on a different port than the API (e.g. Next 3004, API 3003), the browser
# must call the API host explicitly:
NEXT_PUBLIC_API_URL=http://localhost:3003

# Optional: absolute URL of the Next app (QR codes, asset links)
# NEXT_PUBLIC_BASE_URL=http://localhost:3004
